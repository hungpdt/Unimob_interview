# Unity — normalize line endings
* text=auto eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.psd binary
*.pdf binary
*.mp3 binary
*.wav binary
*.ogg binary
*.fbx binary
*.anim binary
*.unity binary
*.prefab binary
*.asset binary
*.mat binary
*.meta text eol=lf
*.cs text eol=lf
*.js text eol=lf
*.json text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf